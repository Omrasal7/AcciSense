ENABLE_OPENCV_FALLBACK=false
ENABLE_TWILIO=false
ENABLE_EMAIL=false

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
