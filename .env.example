APP_NAME=AcciSense API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8000

ACCIDENT_MODEL_PATH=../models/accident_cls.pt
SEVERITY_MODEL_PATH=../models/severity_cls.pt
